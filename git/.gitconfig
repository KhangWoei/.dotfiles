[user]
    name                 = Khang

[core]
    editor               = nvim
    autocrlf             = input
    whitespace           = fix,-indent-with-non-tab,trailing-space,cr-at-eol
    excludesFiles        = ~/.gitignore_global

[pull]
    rebase               = true

[rebase]
    autoStash            = true
    updateRefs           = true

[rerere]
    enabled              = true
    autoupdate           = true

[url "git@github.com:"]
	insteadOf            = https://github.com/

[branch]
    sort                 = -comitterdate

[worktree]
    guessRemote          = true

[alias]
    # ── Branches ────────────────────────────────────────────────────────────────
    main                 = switch main
    new                  = "!f(){ git switch -c $1; }; f"
    visit                = "!f(){ git switch --detach $1; }; f"
    upstream             = "!f() { git branch --set-upstream-to origin/${1}; }; f"
    findb                = "!f(){ git branch --all --contains $1; }; f"
    # Delete             branches already merged into origin/main (or given ref)
    cleanb               = "!f() { git branch --merged ${1:-origin/main} | grep -v '\\*\\|main\\|master' | xargs -r git branch -d; }; f"
    # List br            anches sorted by last commit 
    branches             = branch --sort=-committerdate --format='%(color:yellow)%(refname:short)%(color:reset) - %(contents:subject) %(color:green)(%(committerdate:relative))%(color:reset)'


    # ── Commits ─────────────────────────────────────────────────────────────────
    amend                = commit --amend
    amendf               = commit --amend --no-edit
    uncommit             = reset --soft HEAD^
    save                 = "!f(){ git add -A && git commit -m \"$1\"; }; f"
    undo                 = "!f(){ git reset --soft HEAD~${1:-1}; }; f"
    signoff              = commit --amend --signoff --no-edit
 
    # ── Diffs & inspection ──────────────────────────────────────────────────────
    staged               = diff --cached
    wdiff                = diff --word-diff
    changed              = "!f(){ git diff --name-only HEAD~${1:-1}; }; f"

    # ── Logs ────────────────────────────────────────────────────────────────────
    standup              = log --pretty=format:'%C(yellow)%h%Creset -%Creset %s %Cgreen(%cD) %C(bold blue)<%an>%Creset' --since yesterday
    pretty               = log --graph --oneline --decorate --all
    graph                = -c core.pager='less -SRF' log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''                    %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
    last                 = "!f(){ git log -${1:-10} --oneline; }; f"

    # ── Remote & sync ───────────────────────────────────────────────────────────
    lease                = push --force-with-lease
    sync                 = "!f(){ git pull --rebase && git log ORIG_HEAD.. --oneline; }; f"
    pub                  = "!f(){ git push -u origin $(git branch --show-current); }; f"

    # ── Stash ───────────────────────────────────────────────────────────────────
    mark                 = "!f(){ git stash push -m \"$1\"; }; f"
    stashes              = stash list

    # ── Rebase ──────────────────────────────────────────────────────────────────
    abort                = rebase --abort
    continue             = rebase --continue
    ri                   = "!f(){ git rebase -i HEAD~${1:-3}; }; f" 

    # ── Reset / clean ───────────────────────────────────────────────────────────
    stat                 = status
    restart              = "!f(){ git reset --hard && git clean -fd; }; f"
    reload               = "!f(){ git reset --hard origin/$1 && git clean -fd; }; f"

    # ── Tags ────────────────────────────────────────────────────────────────────
    findt                = "!f(){ git tag --contains $1; }; f"
    release              = "!f(){ git tag -a $1 -m \"Release $1\" && git push origin $1; }; f"

    # ── Reset / clean ───────────────────────────────────────────────────────────
    stat                 = status
    restart              = "!f(){ git reset --hard && git clean -fd; }; f"
    reload               = "!f(){ git reset --hard origin/$1 && git clean -fd; }; f"

    # ── Config ──────────────────────────────────────────────────────────────────
    configurations       = config --list --show-origin
    aliases              = config --get-regexp '^alias\\.'

